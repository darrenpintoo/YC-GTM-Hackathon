# Schrute environment variables
# Copy to .env.local and fill in values.

# Convex (set automatically by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=

# Frontend data source (Darren's surface).
#   unset / anything  -> mock-data mode (default; uses lib/mocks.ts)
#   "false"           -> live Convex (contracts.ts queries + orchestrate.seedDemo)
NEXT_PUBLIC_USE_MOCKS=

# OpenAI — structured extraction, profile clustering, memo generation
OPENAI_API_KEY=

# Fiber AI — enrichment sidecar (contacts, company resolution)
FIBER_API_KEY=
